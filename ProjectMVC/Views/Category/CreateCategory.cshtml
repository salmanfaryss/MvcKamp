@model Entity.Concrete.Category
@{
    ViewBag.Title = "CreateCategory";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>CreateCategory</h2>

@using (Html.BeginForm("CreateCategory", "Category", FormMethod.Post))
            {
                <div class="form-group">
                    @Html.Label("Kategori Adi")
                    @Html.TextBoxFor(x => x.CategoryName, new {@class = "form-control"})
                    @Html.ValidationMessageFor(x => x.CategoryName)
                    <br /><br />
                    @Html.Label("Açıklama")
                    @Html.TextAreaFor(x => x.Description, new  { @class ="form-control"})
                    @Html.ValidationMessageFor(x => x.Description)
                    <br /><br />
                    <button class="btn btn-outline-info">Ekle</button>
                </div>
            }