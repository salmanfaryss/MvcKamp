@model Entity.Concrete.Content
@{
    ViewBag.Title = "CreateContent";
    Layout = "~/Views/Shared/_WriterLayout.cshtml";
}

<br /><br />
@using (Html.BeginForm("CreateContent", "WriterPanelContent", FormMethod.Post))
{
    <div class="form-group">
        @Html.Label("Başlık Adi")
        @Html.DropDownListFor(x => x.HeadingID, (List<SelectListItem>)ViewBag.h, new { @class = "form-control" })
        <br /><br />
        @Html.Label("Yazari")
        @Html.DropDownListFor(x => x.WriterID, (List<SelectListItem>)ViewBag.w, new { @class = "form-control" })
        <br /><br />
              <div class="form-group">
                  @*@Html.Label("Yazım")*@
                  @Html.TextAreaFor(x => x.ContentValue, 10, 30, new { @class = "form-control" })

              </div>
        

        <br /><br />
        <button class="btn btn-outline-info">Kaydet</button>
    </div>
}

