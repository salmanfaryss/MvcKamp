@model Entity.Concrete.Admin
@{
    ViewBag.Title = "UpdateAdmin";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<br />
@using (Html.BeginForm("UpdateAdmin", "Authorization", FormMethod.Post))
{
    <div class="form-group">
        @Html.HiddenFor(x => x.AdminID)
        @Html.Label("Kullanıcı Adi")
        @Html.TextBoxFor(x => x.AdminUserName, new { @class = "form-control" })

        <br /><br />
        @Html.Label("Kullanıcı Şifre")
        @Html.TextAreaFor(x => x.AdminPassword, new { @class = "form-control" })

        <br /><br />
        @Html.Label("Kullanıci Rolü")
        @Html.TextAreaFor(x => x.AdminRole, new { @class = "form-control" })

        <br /><br />
        <button class="btn btn-outline-info">Kaydet</button>
    </div>
}


