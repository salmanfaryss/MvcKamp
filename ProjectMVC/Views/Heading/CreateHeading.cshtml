@using Entity.Concrete
@model Heading
@{
    ViewBag.Title = "CreateHeading";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@using (Html.BeginForm("CreateHeading", "Heading", FormMethod.Post))
{
    <div class="form-group">
        @Html.Label("Başlık Adi")
        @Html.TextBoxFor(x => x.HeadingName, new { @class = "form-control" })

        <br /><br />
        @Html.Label("Kategori")
        @Html.DropDownListFor(x => x.CategoryID, (List<SelectListItem>)ViewBag.k, new { @class = "form-control" })
        <br /><br />
        @Html.Label("Writer")
        @Html.DropDownListFor(x => x.WriterID, (List<SelectListItem>)ViewBag.w, new { @class = "form-control" })

        <br /><br />
        <button class="btn btn-outline-info">Başlık Oluştur</button>
    </div>
}
