@model Entity.Concrete.Heading
@{
    ViewBag.Title = "UpdateHeading";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Başlık Güncelleme Sayfasi</h2>

@using (Html.BeginForm("UpdateHeading", "Heading", FormMethod.Post))
{
    <div class="form-group">
        @Html.HiddenFor(x => x.HeadingID)
        @Html.Label("Başlık Adi")
        @Html.TextBoxFor(x => x.HeadingName, new { @class = "form-control" })

        <br /><br />
        @Html.Label("Kategori")
        @Html.DropDownListFor(x => x.CategoryID, (List<SelectListItem>)ViewBag.k, new { @class = "form-control" })
        <br /><br />
        @Html.Label("Writer")
        @Html.DropDownListFor(x => x.WriterID, (List<SelectListItem>)ViewBag.w, new { @class = "form-control" })
        <br /><br />
        @*@Html.Label("Tarih")
        @Html.TextBoxFor(x => x.Date, new  { @class="form-control"})*@

        <br /><br />
        <button class="btn btn-outline-info">Başlık Oluştur</button>
    </div>
}


